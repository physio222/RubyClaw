# ============================================================================
# RubyClaw Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# --- Backend (API Server) ---
PORT=3000
NODE_ENV=development

# Database (Neon.tech - permanent free tier)
DATABASE_URL=postgresql://user:password@host.neon.tech/rubyclaw?sslmode=require

# AI Provider (OPTIONAL - app works with local LLMs by default)
# Only needed if you want server-side AI processing
AI_INTEGRATIONS_OPENAI_API_KEY=sk-your-key-here
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# CORS (comma-separated origins, use * for development)
ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=info

# --- Mobile App (Expo) ---
# Set this to your deployed backend URL
EXPO_PUBLIC_API_URL=https://rubyclaw-api.onrender.com

# --- CI/CD (GitHub Secrets) ---
# EXPO_TOKEN=your-expo-token
# RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-xxx?key=xxx
