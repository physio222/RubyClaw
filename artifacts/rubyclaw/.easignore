# ============================================================================
# EAS Build Ignore — Exclude monorepo files not needed for mobile app
# This file must be next to eas.json (in artifacts/rubyclaw/)
# Paths are relative to the MONOREPO ROOT (git root)
# ============================================================================

# Other artifacts (not needed for mobile build)
artifacts/api-server/
artifacts/mockup-sandbox/

# Workspace libraries (not imported by mobile app at runtime)
lib/

# CI/CD and DevOps
.github/
scripts/

# Agent configs
.agents/

# Attached screenshots/assets from Replit
attached_assets/

# Docker files
Dockerfile
.dockerignore
render.yaml

# Environment files
.env
.env.example

# Replit files
.replit
replit.nix
replit.md

# Build artifacts
build-log.json

# Config directories
.config/
